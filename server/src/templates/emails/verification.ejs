<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Verify Your Email – CampusGarh</title>
</head>
<body style="margin:0;padding:0;background:#F2EFE9;font-family:'Arial',sans-serif;">
  <div style="max-width:580px;margin:36px auto;border-radius:14px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.13);">

    <!-- Gold top bar -->
    <div style="background:#C9A84C;height:5px;"></div>

    <!-- Header -->
    <div style="background:#0A0A0F;padding:36px 48px;text-align:center;">
      <img src="https://campusgarh.com/favicon/ms-icon-150x150.png" alt="CampusGarh" width="56" height="56" style="display:block;margin:0 auto 14px;border-radius:12px;border:2px solid #C9A84C;padding:2px;">
      <h1 style="margin:0;color:#C9A84C;font-size:26px;font-weight:900;letter-spacing:-0.03em;">CAMPUS<span style="color:#fff;">GARH</span></h1>
      <p style="margin:6px 0 0;color:rgba(201,168,76,0.6);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;">India's Premier Education Portal</p>
    </div>

    <!-- Body -->
    <div style="background:#ffffff;padding:40px 48px;">
      <h2 style="margin:0 0 10px;color:#0A0A0F;font-size:22px;font-weight:800;">Welcome aboard, <%= name %>! 🎓</h2>
      <p style="margin:0 0 20px;color:#555;font-size:14px;line-height:1.8;">Thank you for joining <strong>CampusGarh</strong> — India's student-first college discovery platform. You're one step away from unlocking personalized college recommendations, honest reviews, and expert counselling.</p>
      <p style="margin:0 0 28px;color:#555;font-size:14px;line-height:1.8;">Please verify your email address to activate your account:</p>

      <!-- CTA -->
      <div style="text-align:center;margin:32px 0;">
        <a href="<%= url %>" style="display:inline-block;background:#C9A84C;color:#0A0A0F;text-decoration:none;font-size:15px;font-weight:800;padding:15px 42px;border-radius:50px;letter-spacing:0.02em;">Verify My Email →</a>
      </div>

      <!-- Info box -->
      <div style="background:#FAF7F2;border:1px solid #E8E3DB;border-left:4px solid #C9A84C;border-radius:8px;padding:16px 20px;margin:24px 0;">
        <p style="margin:0;color:#7A6030;font-size:13px;line-height:1.7;">⏳ This link expires in <strong>24 hours</strong>. If you did not create a CampusGarh account, you can safely ignore this email.</p>
      </div>

      <!-- Fallback link -->
      <p style="margin:20px 0 0;color:#999;font-size:12px;line-height:1.7;">Button not working? Copy and paste this link into your browser:<br>
        <a href="<%= url %>" style="color:#C9A84C;word-break:break-all;"><%= url %></a>
      </p>
    </div>

    <!-- No-reply notice -->
    <div style="background:#FFF8EC;padding:16px 48px;border-top:1px solid #F0DEB0;">
      <p style="margin:0;color:#8A6D2F;font-size:12px;line-height:1.7;">⚠️ This is an automated message from <strong>no_reply@campusgarh.com</strong>. Please do not reply — this mailbox is not monitored. For help, write to <a href="mailto:support@campusgarh.com" style="color:#C9A84C;">support@campusgarh.com</a>.</p>
    </div>

    <!-- Footer -->
    <div style="background:#0A0A0F;padding:24px 48px;text-align:center;">
      <p style="margin:0 0 8px;color:rgba(255,255,255,0.3);font-size:11px;letter-spacing:0.05em;">© 2025 CampusGarh Pvt. Ltd. · All rights reserved</p>
      <p style="margin:0;">
        <a href="https://campusgarh.com" style="color:#C9A84C;font-size:11px;text-decoration:none;margin:0 8px;">campusgarh.com</a>
        <span style="color:rgba(255,255,255,0.15);">|</span>
        <a href="https://campusgarh.com/privacy-policy" style="color:rgba(255,255,255,0.3);font-size:11px;text-decoration:none;margin:0 8px;">Privacy Policy</a>
        <span style="color:rgba(255,255,255,0.15);">|</span>
        <a href="https://campusgarh.com/terms-and-conditions" style="color:rgba(255,255,255,0.3);font-size:11px;text-decoration:none;margin:0 8px;">Terms</a>
      </p>
    </div>
    <div style="background:#C9A84C;height:4px;"></div>
  </div>
</body>
</html>
